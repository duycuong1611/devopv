# PostgreSQL
POSTGRES_DB=relayops
POSTGRES_USER=relayops
POSTGRES_PASSWORD=change_this_local_password
DATABASE_URL=postgresql+psycopg://relayops:change_this_local_password@db:5432/relayops

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_TASK_MAX_RETRIES=3

# GitHub webhook security
# Generate one with: ./scripts/generate_secret.sh
GITHUB_WEBHOOK_SECRET=replace_with_a_long_random_secret
MAX_WEBHOOK_BYTES=1048576
WEBHOOK_RATE_LIMIT_PER_MINUTE=60

# Dashboard protection (leave empty only for local development)
DASHBOARD_API_TOKEN=

# Deployment runner
# "simulate" is safe for the portfolio demo.
# "command" runs DEPLOY_COMMAND exactly as configured below; it NEVER interpolates webhook payload values.
DEPLOY_MODE=simulate
DEPLOY_COMMAND=
DEPLOY_TIMEOUT_SECONDS=120

# Optional guards. Leave empty for the demo; set these before a real deployment.
ALLOWED_REPOSITORY=
ALLOWED_BRANCH=

# Application
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
